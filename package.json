{
  "name": "md-review",
  "version": "0.1.0",
  "description": "Review markdown files with inline comments and generate AI prompts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kartikeyam1/md-review.git"
  },
  "homepage": "https://github.com/kartikeyam1/md-review",
  "keywords": [
    "markdown",
    "review",
    "comments",
    "ai",
    "prompt",
    "editor",
    "vue",
    "codemirror"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node --test tests/e2e/app.test.mjs",
    "start": "npx serve dist -s"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/language-data": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "codemirror": "^6.0.0",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.13.0",
    "vue": "^3.5.0",
    "vue-codemirror": "^6.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  }
}
